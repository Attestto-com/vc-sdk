{
  "name": "@attestto/vc-sdk",
  "version": "0.1.0",
  "description": "Universal SDK for issuing and verifying W3C Verifiable Credentials — any schema, any DID method",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "verifiable-credentials",
    "ssi",
    "did",
    "w3c",
    "json-ld",
    "ed25519",
    "es256",
    "credential-issuance",
    "credential-verification"
  ],
  "author": "Attestto Open <open@attestto.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Attestto-com/vc-sdk.git"
  },
  "homepage": "https://github.com/Attestto-com/vc-sdk",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@noble/curves": "^1.8.0",
    "@noble/hashes": "^1.7.0",
    "jose": "^6.0.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=6.4.2",
      "esbuild": ">=0.25.0"
    }
  }
}
